{
  // 是否启用
  "cc-statusbar.enabled": true,

  // 刷新间隔（秒），建议 5~10
  "cc-statusbar.refreshSeconds": 10,

  // 位置：left / right
  "cc-statusbar.alignment": "right",

  // 语言：auto / en / ru
  "cc-statusbar.language": "auto",

  // 缓存权重（影响 cost 计算，默认 0.1）
  "cc-statusbar.cacheReadWeight": 0.1,

  // 显示内容开关
  "cc-statusbar.showCost": true,        // 费用
  "cc-statusbar.showTokens": true,      // token 数
  "cc-statusbar.showQuota": true,        // 配额（5h/7d）
  "cc-statusbar.showContext": true,      // 上下文占用
  "cc-statusbar.showModel": true,        // 当前模型

  // 颜色（可选，十六进制）
  "cc-statusbar.color": "#4ec9b0",
  "cc-statusbar.warningColor": "#ffcc00",
  "cc-statusbar.dangerColor": "#ff4444"
}